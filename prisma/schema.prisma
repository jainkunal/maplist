generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                  String      @id @default(uuid())
  name                String
  email               String      @unique
  emailVerified       Boolean     @default(false)
  image               String?
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt
  monetizationStatus  String      @default("none")
  isAdmin             Boolean     @default(false)
  sessions            Session[]
  accounts            Account[]
  lists               List[]
  followers           Follow[]      @relation("Followers")
  following           Follow[]      @relation("Following")
  savedLists          SavedList[]
  placeReviews        PlaceReview[]
  purchases           Purchase[]
  payouts             Payout[]
}

model Follow {
  followerId  String
  followingId String
  createdAt   DateTime @default(now())
  follower    User     @relation("Following", fields: [followerId], references: [id], onDelete: Cascade)
  following   User     @relation("Followers", fields: [followingId], references: [id], onDelete: Cascade)

  @@id([followerId, followingId])
}

model Session {
  id        String   @id @default(uuid())
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                    String    @id @default(uuid())
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?   @db.Text
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
}

model Verification {
  id         String   @id @default(uuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model List {
  id                 String      @id @default(uuid())
  title              String
  description        String      @default("")
  isPublic           Boolean     @default(false)
  isPremium          Boolean     @default(false)
  premiumPrice       Float?
  premiumDescription String      @default("")
  createdAt          DateTime    @default(now())
  thumbnailUrl       String?
  status             String      @default("ready")
  processingInput    String?     @db.Text
  places             Place[]
  userId             String?
  user               User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  dodoProductId      String?
  savedBy            SavedList[]
  purchases          Purchase[]
}

model SavedList {
  userId    String
  listId    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  list      List     @relation(fields: [listId], references: [id], onDelete: Cascade)

  @@id([userId, listId])
}

model UnsupportedLink {
  id        String   @id @default(uuid())
  url       String
  platform  String
  createdAt DateTime @default(now())
}

model Place {
  id             String        @id @default(uuid())
  name           String
  lat            Float
  lng            Float
  tags           String[]
  notes          String        @default("")
  recommendedBy  String        @default("")
  visited        Boolean       @default(false)
  order          Int           @default(0)
  googlePlaceId  String        @default("")
  photoUrl       String?
  listId         String
  list           List          @relation(fields: [listId], references: [id], onDelete: Cascade)
  reviews        PlaceReview[]
}

model PlaceReview {
  id        String   @id @default(uuid())
  rating    Int      // 1-5
  comment   String   @default("")
  visited   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  placeId   String
  place     Place    @relation(fields: [placeId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([placeId, userId])
}

model Purchase {
  id            String   @id @default(uuid())
  userId        String
  listId        String
  paymentId     String   @unique
  amount        Int
  currency      String   @default("USD")
  creatorShare  Int
  platformShare Int
  createdAt     DateTime @default(now())
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  list          List     @relation(fields: [listId], references: [id], onDelete: Cascade)

  @@unique([userId, listId])
}

model Payout {
  id        String   @id @default(uuid())
  userId    String
  amount    Int
  note      String   @default("")
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
